<%- include('layouts/header') %>
<%- include('layouts/navbar') %>

<div class="container my-5">
    <div class="row">
        <div class="col-md-12">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3 class="card-title mb-0">Danh sách các địa điểm / Sản phẩm</h3>
                </div>
                <div class="card-body">
                    <table class="table table-bordered table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th scope="col" style="width: 10%;">ID</th>
                                <th scope="col">Tên địa điểm</th>
                                <th scope="col" style="width: 20%;">Trạng thái</th>
                                <th scope="col" style="width: 15%;">Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (danhSach && danhSach.length > 0) { %>
                                <% danhSach.forEach(function(item) { %>
                                    <tr>
                                        <td><%= item.id %></td>
                                        <td><%= item.name %></td>
                                        <td>
                                            <% if (item.hot) { %>
                                                <span class="badge bg-danger text-white">
                                                    <i class="fas fa-fire"></i> HOT
                                                </span>
                                            <% } else { %>
                                                <span class="badge bg-secondary">Bình thường</span>
                                            <% } %>
                                        </td>
                                        <td class="text-center">
                                            <a href="/detail/<%= item.id %>" class="btn btn-sm btn-info text-white">
                                                <i class="fas fa-eye"></i> Xem chi tiết
                                            </a>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="4" class="text-center">Không có dữ liệu hiển thị</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
                <div class="card-footer text-muted">
                    Cập nhật từ hệ thống quản lý Tech Review
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('layouts/footer') %>